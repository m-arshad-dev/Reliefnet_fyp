# Postgres connection string (Railway injects this automatically in prod)
DATABASE_URL=postgres://reliefnet:reliefnet@localhost:5432/reliefnet

# JWT — use long random strings in prod; secrets MUST be distinct for access vs refresh
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Beneficiary CNIC hash pepper (Slice 5) — a real deploy secret, set in Railway and
# NEVER committed. Use a long random string in prod; raw CNICs are never stored.
CNIC_PEPPER=dev-cnic-pepper-change-me

# Allowed browser origin for CORS (set to the Vercel URL in prod)
CORS_ORIGIN=http://localhost:5173

# HTTP port
PORT=4000

# Seed system admin — consumed by the seed migration at migrate time (not by the app)
SEED_ADMIN_EMAIL=admin@reliefnet.org
SEED_ADMIN_PASSWORD=ChangeMe123!
